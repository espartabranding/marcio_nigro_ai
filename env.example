"""
Ingestão de documentos → chunk → embed → upsert Pinecone
Suporta: PDF, TXT, DOCX, MD
"""

from fastapi import APIRouter, UploadFile, File, Depends, HTTPException, Form
from typing import Optional, List
import httpx
import hashlib
import uuid
import io

from core.auth import get_client
from core.database import log_usage, log_ingestion

router = APIRouter()

EMBED_MODEL = "multilingual-e5-large"
CHUNK_SIZE = 800       # caracteres
CHUNK_OVERLAP = 150    # overlap entre chunks

# ─── Extração de texto ────────────────────────────────────────────────────────

async def extract_text(file: UploadFile) -> str:
    content = await file.read()
    filename = file.filename.lower()

    if filename.endswith(".txt") or filename.endswith(".md"):
        return content.decode("utf-8", errors="ignore")

    if filename.endswith(".pdf"):
        try:
            import pdfplumber
            with pdfplumber.open(io.BytesIO(content)) as pdf:
                return "\n".join(p.extract_text() or "" for p in pdf.pages)
        except ImportError:
            raise HTTPException(status_code=422, detail="pdfplumber não instalado. Instale: pip install pdfplumber")

    if filename.endswith(".docx"):
        try:
            from docx import Document
            doc = Document(io.BytesIO(content))
            return "\n".join(p.text for p in doc.paragraphs)
        except ImportError:
            raise HTTPException(status_code=422, detail="python-docx não instalado. Instale: pip install python-docx")

    raise HTTPException(status_code=415, detail=f"Formato não suportado: {filename}. Use PDF, TXT, DOCX ou MD.")

# ─── Chunking ─────────────────────────────────────────────────────────────────

def chunk_text(text: str, chunk_size: int = CHUNK_SIZE, overlap: int = CHUNK_OVERLAP) -> List[str]:
    text = " ".join(text.split())  # normaliza espaços
    chunks = []
    start = 0
    while start < len(text):
        end = min(start + chunk_size, len(text))
        chunk = text[start:end].strip()
        if chunk:
            chunks.append(chunk)
        start += chunk_size - overlap
    return chunks

# ─── Embedding via Pinecone Inference ─────────────────────────────────────────

async def embed_chunks(chunks: List[str], pinecone_api_key: str) -> List[List[float]]:
    async with httpx.AsyncClient(timeout=60) as client:
        resp = await client.post(
            "https://api.pinecone.io/embed",
            headers={"Api-Key": pinecone_api_key, "Content-Type": "application/json"},
            json={
                "model": EMBED_MODEL,
                "inputs": [{"text": c} for c in chunks],
                "parameters": {"input_type": "passage", "truncate": "END"},
            },
        )
    if resp.status_code != 200:
        raise HTTPException(status_code=502, detail=f"Pinecone embed error: {resp.text}")
    data = resp.json()
    return [item["values"] for item in data["data"]]

# ─── Upsert no Pinecone ───────────────────────────────────────────────────────

async def upsert_vectors(
    vectors: list,
    pinecone_host: str,
    pinecone_api_key: str,
    namespace: str,
    batch_size: int = 100,
):
    host = pinecone_host if pinecone_host.startswith("http") else f"https://{pinecone_host}"
    async with httpx.AsyncClient(timeout=60) as client:
        for i in range(0, len(vectors), batch_size):
            batch = vectors[i : i + batch_size]
            resp = await client.post(
                f"{host}/vectors/upsert",
                headers={"Api-Key": pinecone_api_key, "Content-Type": "application/json"},
                json={"vectors": batch, "namespace": namespace},
            )
            if resp.status_code != 200:
                raise HTTPException(status_code=502, detail=f"Pinecone upsert error: {resp.text}")

# ─── Endpoints ────────────────────────────────────────────────────────────────

@router.post("/document")
async def ingest_document(
    file: UploadFile = File(...),
    namespace_override: Optional[str] = Form(None),
    extra_metadata: Optional[str] = Form(None),  # JSON string
    client: dict = Depends(get_client),
):
    """
    Ingere um documento (PDF, TXT, DOCX, MD) no Pinecone do cliente.
    - Extrai texto
    - Faz chunking com overlap
    - Embeda via Pinecone Inference (multilingual-e5-large)
    - Faz upsert com metadata rico
    """
    namespace = namespace_override or client["namespace"]
    filename = file.filename

    # Extrai texto
    text = await extract_text(file)
    if not text.strip():
        raise HTTPException(status_code=422, detail="Documento vazio ou sem texto extraível.")

    # Chunking
    chunks = chunk_text(text)
    if not chunks:
        raise HTTPException(status_code=422, detail="Nenhum chunk gerado.")

    # Embedding
    embeddings = await embed_chunks(chunks, client["pinecone_api_key"])

    # Monta vetores com metadata
    import json
    extra_meta = {}
    if extra_metadata:
        try:
            extra_meta = json.loads(extra_metadata)
        except Exception:
            pass

    doc_id = hashlib.md5(filename.encode()).hexdigest()[:8]

    vectors = []
    for i, (chunk, embedding) in enumerate(zip(chunks, embeddings)):
        vectors.append({
            "id": f"{doc_id}_chunk_{i}",
            "values": embedding,
            "metadata": {
                "source": filename,
                "chunk_index": i,
                "total_chunks": len(chunks),
                "text": chunk,
                "client_id": client["id"],
                **extra_meta,
            },
        })

    # Upsert
    await upsert_vectors(vectors, client["pinecone_host"], client["pinecone_api_key"], namespace)

    # Log
    log_ingestion(client["id"], filename, len(chunks), "success")
    log_usage(client["id"], "/ingest/document")

    return {
        "status": "success",
        "filename": filename,
        "chunks_ingested": len(chunks),
        "namespace": namespace,
        "vector_ids": [v["id"] for v in vectors],
    }


@router.post("/text")
async def ingest_text(
    text: str = Form(...),
    source_name: str = Form("manual_input"),
    namespace_override: Optional[str] = Form(None),
    extra_metadata: Optional[str] = Form(None),
    client: dict = Depends(get_client),
):
    """Ingere texto direto (sem arquivo) — útil para FAQ, perfis de ICP, etc."""
    import json
    namespace = namespace_override or client["namespace"]
    chunks = chunk_text(text)
    embeddings = await embed_chunks(chunks, client["pinecone_api_key"])

    extra_meta = {}
    if extra_metadata:
        try:
            extra_meta = json.loads(extra_metadata)
        except Exception:
            pass

    doc_id = hashlib.md5(source_name.encode()).hexdigest()[:8]
    vectors = []
    for i, (chunk, embedding) in enumerate(zip(chunks, embeddings)):
        vectors.append({
            "id": f"{doc_id}_chunk_{i}_{uuid.uuid4().hex[:4]}",
            "values": embedding,
            "metadata": {
                "source": source_name,
                "chunk_index": i,
                "total_chunks": len(chunks),
                "text": chunk,
                "client_id": client["id"],
                **extra_meta,
            },
        })

    await upsert_vectors(vectors, client["pinecone_host"], client["pinecone_api_key"], namespace)
    log_ingestion(client["id"], source_name, len(chunks), "success")
    log_usage(client["id"], "/ingest/text")

    return {
        "status": "success",
        "source": source_name,
        "chunks_ingested": len(chunks),
        "namespace": namespace,
    }
